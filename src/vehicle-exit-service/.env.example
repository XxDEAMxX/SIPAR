# Endpoint receptor de detecciones en tu backend.
# Ejemplo: http://127.0.0.1:8000/api/vehicle-entry
BACKEND_ENDPOINT=

# Configuracion de camara
CAMERA_INDEX=0
CAMERA_ID=entry-cam-1

# Frecuencia y control de eventos
CAPTURE_INTERVAL_SECONDS=0.05
PLATE_COOLDOWN_SECONDS=3
MIN_PLATE_CONFIDENCE=0.4
MIN_DETECTION_CONFIDENCE=0.3
BACKEND_TIMEOUT_SECONDS=5

# Modelos fast_alpr (opcional)
ALPR_DETECTOR_MODEL=yolo-v9-t-384-license-plate-end2end
ALPR_OCR_MODEL=cct-xs-v1-global-model
