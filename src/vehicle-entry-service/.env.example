# Endpoint receptor de detecciones en tu backend.
# Ejemplo: http://127.0.0.1:8000/api/parking/detections
BACKEND_ENDPOINT=http://127.0.0.1:8000/api/parking/detections
SERVICE_API_KEY=nuvora-service-key-2024-change-in-prod
DETECTION_DIRECTION=entry
SOURCE_NAME=vehicle-entry-service

# Configuracion de camara
CAMERA_INDEX=0
CAMERA_ID=entry-cam-1

# Frecuencia y control de eventos
CAPTURE_INTERVAL_SECONDS=0.05
PLATE_COOLDOWN_SECONDS=3
CONSENSUS_WINDOW_SECONDS=1.0
CONSENSUS_MIN_OBSERVATIONS=2
CONSENSUS_MIN_SUPPORT=3
CONSENSUS_MIN_CONFIDENCE=0.90
MIN_PLATE_CONFIDENCE=0.6
IMMEDIATE_EMIT_PLATE_CONFIDENCE=0.98
IMMEDIATE_EMIT_MIN_HITS=2
POST_EMIT_LOCK_SECONDS=4.0
PRESENCE_RESET_SECONDS=2.0
MIN_DETECTION_CONFIDENCE=0.3
BACKEND_TIMEOUT_SECONDS=5

# Modelos fast_alpr (opcional)
ALPR_DETECTOR_MODEL=yolo-v9-t-384-license-plate-end2end
ALPR_OCR_MODEL=cct-xs-v1-global-model
